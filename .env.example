# LLM API
OPENAI_API_KEY=sk_xxx
OPENAI_API_BASE=https://api.custom-llm.example.com
OPENAI_MODEL=my-llm-chat-1

# Google OAuth (Gmail + Google Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/oauth2callback

# App settings
LOG_LEVEL=INFO
DRY_RUN=false  # set to false to allow actual calendar writes
